{
  "name": "",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:translations && vite build",
    "check:translations": "node scripts/check-translations.mjs",
    "lint": "npm run lint:structure && eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:structure": "node scripts/check-structure.mjs",
    "lint:architecture": "node scripts/check-structure.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "start:server": "node server/index.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google/genai": "^1.12.0",
    "@types/dompurify": "^3.0.5",
    "cors": "^2.8.5",
    "dompurify": "^3.4.11",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.6.1",
    "node-cron": "^4.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router-dom": "^6.30.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
