# Copy this to server/.env and set real values. Do NOT commit secrets to source control.

# Gemini API key — server only, never exposed to the browser
GEMINI_API_KEY=your_server_side_gemini_key_here

# Token the frontend must present in Authorization: Bearer <token>
SERVER_CLIENT_TOKEN=replace_with_strong_token

# Default model (used when per-task overrides are not set)
GEMINI_MODEL=gemini-2.5-flash

# Per-task model selection (server-managed)
GEMINI_MODEL_WEBSITE=gemini-2.5-flash
GEMINI_MODEL_NEWSLETTER=gemini-2.5-flash
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash

# Generation parameters
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95

# Consent version enforced on AI routes
AI_CONSENT_VERSION=2026-06-21

# Quotas per client (X-Client-ID) or IP
DAILY_QUOTA=100
MONTHLY_QUOTA=1000

# Short-term rate limiter for AI generation routes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Admin token for /api/v1/logs and /api/v1/audit
ADMIN_TOKEN=replace_with_admin_token

# Optional Redis for quota tracking
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=5174
