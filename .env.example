# Copy this file to .env for local development.
# Never commit .env to version control.

# Client gateway token — same value as SERVER_CLIENT_TOKEN in server/.env (NOT the Gemini key)
VITE_SERVER_CLIENT_TOKEN=replace_with_a_long_random_value

# Optional: override API base URL (defaults to same origin / Vite proxy in dev)
# VITE_API_BASE_URL=
